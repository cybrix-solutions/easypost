{
    "name": "cybrix-solutions/easypost",
    "description": "Shipment functionality for EasyPost API.",
    "keywords": [
        "cybrix-solutions",
        "laravel",
        "easypost"
    ],
    "homepage": "https://github.com/cybrix-solutions/easypost",
    "license": "MIT",
    "authors": [
        {
            "name": "Randall Wilk",
            "email": "randall.wilk@cybrixsolutions.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2",
        "illuminate/contracts": "^10.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^7.9",
        "orchestra/testbench": "^8.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-arch": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "spatie/laravel-ray": "^1.31"
    },
    "autoload": {
        "psr-4": {
            "CybrixSolutions\\EasyPost\\": "src/",
            "CybrixSolutions\\EasyPost\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CybrixSolutions\\EasyPost\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CybrixSolutions\\EasyPost\\EasyPostServiceProvider"
            ],
            "aliases": {
                "EasyPost": "EasyPost"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}